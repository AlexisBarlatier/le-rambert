---
import { t, type Lang } from '../i18n/utils';

interface Tarifs {
  semaine: number;
  nuit: number;
  nuit_minimum: number;
  menage: {
    prix: number;
    description: string;
  };
}
interface Props {
  tarifs: Tarifs;
  lang?: Lang;
}
const { tarifs, lang = 'fr' } = Astro.props;

const formatPrice = (n: number) => n.toLocaleString(lang === 'en' ? 'en-GB' : 'fr-FR');
---

<section id="tarifs" class="tarifs">
  <p class="section-tag">{t(lang, 'pricing.tag')}</p>
  <h2 class="section-title" set:html={t(lang, 'pricing.title')} />
  <div class="tarifs-flex">
    <div class="tarif-block featured" data-animate>
      <div class="tarif-price">{formatPrice(tarifs.semaine)} €</div>
      <div class="tarif-unit">{t(lang, 'pricing.week')}</div>
    </div>
    <div class="tarif-block" data-animate>
      <div class="tarif-price">{formatPrice(tarifs.nuit)} €</div>
      <div class="tarif-unit">{t(lang, 'pricing.night')}</div>
      <div class="tarif-note">{t(lang, 'pricing.minimum').replace('{n}', String(tarifs.nuit_minimum))}</div>
    </div>
  </div>
  <div class="tarifs-mention">
    <strong set:html={t(lang, 'pricing.cleaning.label').replace('{price}', formatPrice(tarifs.menage.prix))} />
    <p>{tarifs.menage.description}</p>
  </div>
</section>

<style>
  .tarifs {
    background: var(--color-text);
    color: var(--color-bg);
    text-align: center;
    padding: 6rem 2rem;
  }

  .tarifs :global(.section-tag) {
    color: var(--color-gold-light);
  }

  .tarifs :global(.section-title) {
    color: var(--color-bg);
  }

  .tarifs :global(.section-title em) {
    color: var(--color-light);
  }

  .tarifs-flex {
    display: flex;
    justify-content: center;
    gap: 3rem;
    margin: 3rem auto 2.5rem;
    flex-wrap: wrap;
  }

  .tarif-block {
    padding: 2.5rem 3rem;
    border: 1px solid rgba(212, 197, 178, 0.15);
    min-width: 240px;
  }

  .tarif-block.featured {
    border-color: var(--color-gold);
    background: rgba(184, 150, 90, 0.06);
  }

  .tarif-price {
    font-family: var(--font-heading);
    font-size: 3rem;
    font-weight: 300;
    color: var(--color-gold-light);
    line-height: 1;
  }

  .tarif-unit {
    font-size: 0.85rem;
    color: var(--color-light);
    margin-top: 0.5rem;
  }

  .tarif-note {
    font-size: 0.78rem;
    color: var(--color-taupe);
    margin-top: 0.3rem;
  }

  .tarifs-mention {
    max-width: 550px;
    margin: 0 auto;
    padding: 1.5rem 2rem;
    border-top: 1px solid rgba(212, 197, 178, 0.12);
  }

  .tarifs-mention strong {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 500;
    display: block;
    margin-bottom: 0.3rem;
    color: var(--color-light);
  }

  .tarifs-mention p {
    font-size: 0.85rem;
    color: var(--color-taupe);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .tarifs-flex { gap: 1.5rem; }
    .tarif-block { padding: 2rem; min-width: auto; width: 100%; max-width: 300px; }
  }
</style>
