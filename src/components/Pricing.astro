---
interface Tarifs {
  semaine: number;
  nuit: number;
  nuit_minimum: number;
  menage: {
    prix: number;
    description: string;
  };
}
interface Props {
  tarifs: Tarifs;
}
const { tarifs } = Astro.props;

const formatPrice = (n: number) => n.toLocaleString('fr-FR');
---

<section id="tarifs" class="pricing">
  <h2>Tarifs</h2>
  <div class="pricing-cards">
    <div class="card">
      <div class="price">{formatPrice(tarifs.semaine)} €</div>
      <div class="unit">par semaine</div>
    </div>
    <div class="card">
      <div class="price">{formatPrice(tarifs.nuit)} €</div>
      <div class="unit">par nuit</div>
      <div class="note">Minimum {tarifs.nuit_minimum} nuits</div>
    </div>
  </div>
  <div class="menage">
    <p><strong>Forfait ménage obligatoire : {formatPrice(tarifs.menage.prix)} € TTC</strong></p>
    <p>{tarifs.menage.description}</p>
  </div>
</section>

<style>
  .pricing {
    padding: 6rem 2rem;
    text-align: center;
  }

  .pricing h2 {
    font-family: var(--font-heading);
    font-size: 2rem;
    margin-bottom: 3rem;
    font-weight: 400;
  }

  .pricing-cards {
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .card {
    padding: 2.5rem 3rem;
    border: 1px solid var(--color-light);
  }

  .price {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    color: var(--color-accent);
  }

  .unit {
    margin-top: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.8rem;
  }

  .note {
    margin-top: 0.5rem;
    font-size: 0.85rem;
    color: #888;
    font-style: italic;
  }

  .menage {
    max-width: 500px;
    margin: 0 auto;
    padding: 1.5rem;
    background: white;
    border: 1px solid var(--color-light);
    font-size: 0.9rem;
  }

  .menage p + p {
    margin-top: 0.5rem;
    color: #666;
  }
</style>
