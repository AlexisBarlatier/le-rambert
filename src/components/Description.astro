---
import { t, type Lang } from '../i18n/utils';

interface Espace {
  titre: string;
  items: string[];
}
interface Chambre {
  type: string;
  nombre: number;
}
interface Props {
  intro: string;
  espaces: Espace[];
  chambres: Chambre[];
  salles_de_bain: number;
  lang?: Lang;
}
const { intro, espaces, chambres, salles_de_bain, lang = 'fr' } = Astro.props;

const icons: Record<string, string> = {
  'Pièces de vie': '🏡',
  'Living areas': '🏡',
  'Terrasses': '☀️',
  'Terraces': '☀️',
  'Piscine': '💧',
  'Pool': '💧',
  'Chambres': '🛏️',
  'Bedrooms': '🛏️',
};
---

<section id="decouvrir" class="intro-section">
  <p class="section-tag">{t(lang, 'desc.tag')}</p>
  <div class="gold-line"></div>
  <p class="intro-text">{intro}</p>
</section>

<section id="espaces" class="espaces">
  <div class="espaces-inner">
    <p class="section-tag">{t(lang, 'desc.espaces.tag')}</p>
    <h2 class="section-title" set:html={t(lang, 'desc.espaces.title')} />
    <p class="section-lead">{t(lang, 'desc.espaces.lead')}</p>
    <div class="espaces-grid">
      {espaces.map(({ titre, items }) => (
        <div class="espace-card" data-animate>
          <div class="espace-icon">{icons[titre] || '✦'}</div>
          <h3>{titre}</h3>
          <ul>
            {items.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      ))}
      <div class="espace-card" data-animate>
        <div class="espace-icon">🛏️</div>
        <h3>{t(lang, 'desc.chambres')}</h3>
        <ul>
          {chambres.map(({ type, nombre }) => <li>{nombre} × {type}</li>)}
          <li>{salles_de_bain} {t(lang, 'desc.bathrooms')}</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .intro-section {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
    padding: 7rem 2rem;
  }

  .gold-line {
    width: 50px;
    height: 1px;
    background: var(--color-gold);
    margin: 2rem auto;
  }

  .intro-text {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 300;
    line-height: 1.9;
    color: var(--color-accent);
    max-width: 680px;
    margin: 0 auto;
  }

  .espaces {
    background: var(--color-warm-white, #FFFCF8);
    padding: 6rem 2rem;
  }

  .espaces-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .espaces-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2rem;
  }

  .espace-card {
    padding: 2.5rem 2rem;
    background: var(--color-bg);
    border: 1px solid rgba(212, 197, 178, 0.4);
    transition: all 0.4s;
    position: relative;
    overflow: hidden;
  }

  .espace-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--color-gold), var(--color-gold-light));
    transform: scaleX(0);
    transition: transform 0.4s;
  }

  .espace-card:hover::before {
    transform: scaleX(1);
  }

  .espace-card:hover {
    box-shadow: 0 12px 40px rgba(30, 21, 16, 0.06);
  }

  .espace-icon {
    font-size: 1.8rem;
    margin-bottom: 1rem;
  }

  .espace-card h3 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 500;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .espace-card ul {
    list-style: none;
  }

  .espace-card li {
    font-size: 0.92rem;
    color: var(--color-accent);
    padding: 0.35rem 0;
    border-bottom: 1px solid rgba(212, 197, 178, 0.25);
  }

  .espace-card li:last-child {
    border: none;
  }
</style>
