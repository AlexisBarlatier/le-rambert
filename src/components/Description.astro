---
interface Espace {
  titre: string;
  items: string[];
}
interface Chambre {
  type: string;
  nombre: number;
}
interface Props {
  intro: string;
  espaces: Espace[];
  chambres: Chambre[];
  salles_de_bain: number;
}
const { intro, espaces, chambres, salles_de_bain } = Astro.props;
---

<section id="decouvrir" class="description">
  <div class="intro">
    <p class="lead">{intro}</p>
  </div>

  <div class="spaces">
    <h2>Les espaces</h2>
    <div class="spaces-grid">
      {espaces.map(({ titre, items }) => (
        <div class="space">
          <h3>{titre}</h3>
          <ul>
            {items.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      ))}
      <div class="space">
        <h3>Chambres</h3>
        <ul>
          {chambres.map(({ type, nombre }) => <li>{nombre} × {type}</li>)}
          <li>{salles_de_bain} salles de bain</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .description {
    padding: 6rem 2rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .intro {
    text-align: center;
    margin-bottom: 4rem;
  }

  .lead {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    line-height: 1.8;
    color: var(--color-accent);
  }

  .spaces h2 {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 400;
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .spaces-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2.5rem;
  }

  .space h3 {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 400;
    margin-bottom: 1rem;
    color: var(--color-accent);
  }

  .space ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .space li {
    padding-left: 1rem;
    position: relative;
    font-size: 0.95rem;
  }

  .space li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-light);
  }
</style>
