---
interface Commodite {
  icon: string;
  label: string;
  detail?: string;
}
interface Props {
  commodites: Commodite[];
}
const { commodites } = Astro.props;
---

<section id="equipements" class="amenities">
  <h2>Commodités</h2>
  <ul class="amenities-grid">
    {commodites.map(({ icon, label, detail }) => (
      <li>
        <span class="icon">{icon}</span>
        <span class="label">{label}</span>
        {detail && <span class="detail">{detail}</span>}
      </li>
    ))}
  </ul>
</section>

<style>
  .amenities {
    padding: 6rem 2rem;
    background: white;
    text-align: center;
  }

  .amenities h2 {
    font-family: var(--font-heading);
    font-size: 2rem;
    margin-bottom: 3rem;
    font-weight: 400;
  }

  .amenities-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 2.5rem;
    list-style: none;
    max-width: 900px;
    margin: 0 auto;
  }

  .amenities-grid li {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
  }

  .icon {
    font-size: 2rem;
    margin-bottom: 0.3rem;
  }

  .label {
    font-weight: 500;
  }

  .detail {
    font-size: 0.85rem;
    color: #888;
  }
</style>
