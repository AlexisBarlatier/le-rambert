---
interface Commodite {
  icon: string;
  label: string;
  detail?: string;
}
interface Props {
  commodites: Commodite[];
}
const { commodites } = Astro.props;
---

<section id="commodites">
  <div class="commodites">
    <p class="section-tag">Équipements</p>
    <h2 class="section-title">Tout le <em>confort</em></h2>
    <p class="section-lead">Pour un séjour sans compromis.</p>
    <div class="commodites-grid">
      {commodites.map(({ icon, label, detail }) => (
        <div class="commodite" data-animate>
          <div class="commodite-icon">{icon}</div>
          <div class="commodite-text">
            <h4>{label}</h4>
            {detail && <p>{detail}</p>}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  section {
    padding: 6rem 2rem;
  }

  .commodites {
    max-width: 1100px;
    margin: 0 auto;
  }

  .commodites-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }

  .commodite {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.5rem;
    background: var(--color-warm-white, #FFFCF8);
    border: 1px solid rgba(212, 197, 178, 0.3);
    transition: all 0.3s;
  }

  .commodite:hover {
    border-color: var(--color-gold-light);
    box-shadow: 0 4px 20px rgba(30, 21, 16, 0.04);
  }

  .commodite-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(184, 150, 90, 0.1), rgba(184, 150, 90, 0.05));
    border-radius: 50%;
  }

  .commodite-text h4 {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .commodite-text p {
    font-size: 0.82rem;
    color: var(--color-taupe);
    margin-top: 0.15rem;
  }
</style>
