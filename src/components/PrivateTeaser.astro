---
import { t, type Lang } from '../i18n/utils';

interface Props {
  lang?: Lang;
}
const { lang = 'fr' } = Astro.props;
---

<section id="acces-prive" class="private-teaser">
  <p class="section-tag">{t(lang, 'private.tag')}</p>
  <h2 class="section-title" set:html={t(lang, 'private.title')} />
  <p class="teaser-text">{t(lang, 'private.text')}</p>
  <form class="gate-form" method="POST" action="/api/auth">
    <input type="hidden" name="lang" value={lang} />
    <input type="email" name="email" placeholder={t(lang, 'private.email')} required />
    <input type="password" name="password" placeholder={t(lang, 'private.password')} required />
    <button type="submit">{t(lang, 'private.submit')}</button>
    <p class="rgpd">{t(lang, 'private.rgpd')}</p>
  </form>
</section>

<style>
  .private-teaser {
    padding: 6rem 2rem;
    background: var(--color-deep);
    color: var(--color-bg);
    text-align: center;
  }

  .private-teaser :global(.section-tag) {
    color: var(--color-gold-light);
  }

  .private-teaser :global(.section-title) {
    color: var(--color-bg);
  }

  .private-teaser :global(.section-title em) {
    color: var(--color-gold-light);
  }

  .teaser-text {
    max-width: 550px;
    margin: 0 auto 2rem;
    color: var(--color-light);
    font-size: 1rem;
    font-weight: 300;
  }

  .gate-form {
    max-width: 400px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .gate-form input {
    padding: 1rem 1.2rem;
    border: 1px solid rgba(212, 197, 178, 0.2);
    background: rgba(255, 255, 255, 0.06);
    color: var(--color-bg);
    font-family: var(--font-body);
    font-size: 0.92rem;
    font-weight: 300;
    outline: none;
    transition: border-color 0.3s;
  }

  .gate-form input:focus {
    border-color: var(--color-gold);
  }

  .gate-form input::placeholder {
    color: rgba(255, 255, 255, 0.4);
  }

  .gate-form button {
    padding: 1.1rem 3rem;
    background: var(--color-gold);
    color: var(--color-deep);
    border: none;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 400;
    cursor: pointer;
    transition: all 0.3s;
    align-self: center;
  }

  .gate-form button:hover {
    background: var(--color-gold-light);
  }

  .rgpd {
    font-size: 0.72rem;
    color: var(--color-taupe);
    margin-bottom: 0;
  }
</style>
