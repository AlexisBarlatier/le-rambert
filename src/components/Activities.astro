---
interface Activite {
  titre: string;
  items: string[];
}
interface Props {
  activites: Activite[];
}
const { activites } = Astro.props;
---

<section class="perigord" id="perigord">
  <div class="perigord-inner">
    <p class="section-tag">À découvrir</p>
    <h2 class="section-title">Le Périgord <em>Noir</em></h2>
    <p class="section-lead">Un patrimoine exceptionnel à portée de main.</p>
    <div class="perigord-cols">
      {activites.map(({ titre, items }) => (
        <div class="perigord-col" data-animate>
          <h3>{titre}</h3>
          <ul>
            {items.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .perigord {
    padding: 6rem 2rem;
    background: linear-gradient(180deg, var(--color-bg), var(--color-warm-white, #FFFCF8));
  }

  .perigord-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .perigord-cols {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 3rem;
  }

  .perigord-col h3 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 1rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid var(--color-stone);
  }

  .perigord-col ul {
    list-style: none;
  }

  .perigord-col li {
    font-size: 0.95rem;
    color: var(--color-accent);
    padding: 0.5rem 0;
    padding-left: 1.2rem;
    position: relative;
  }

  .perigord-col li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-gold);
  }
</style>
