---
import fs from 'node:fs';
import path from 'node:path';

interface Props {
  title: string;
  subtitle: string;
  location: string;
}
const { title, subtitle, location } = Astro.props;

// Trouver la première image dans hero/
const heroDir = path.resolve('public/photos/hero');
const heroFiles = fs.existsSync(heroDir)
  ? fs.readdirSync(heroDir).filter(f => /\.(jpe?g|png|webp)$/i.test(f)).sort()
  : [];
const heroImage = heroFiles.length > 0 ? `/photos/hero/${heroFiles[0]}` : null;
---

<section id="hero" class="hero" style={heroImage ? `background-image: linear-gradient(rgba(0,0,0,0.35), rgba(0,0,0,0.35)), url('${heroImage}')` : undefined}>
  <div class="hero-content">
    <h1>{title}</h1>
    <p class="tagline">{subtitle}</p>
    <p class="location">{location}</p>
    <a href="#contact" class="cta">Réserver</a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-accent);
    background-size: cover;
    background-position: center;
    color: white;
    text-align: center;
  }

  .hero-content h1 {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 400;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .tagline {
    font-size: clamp(1rem, 2.5vw, 1.5rem);
    font-weight: 300;
    margin-bottom: 0.5rem;
    opacity: 0.9;
  }

  .location {
    font-size: clamp(0.85rem, 2vw, 1.1rem);
    font-weight: 300;
    margin-bottom: 2.5rem;
    opacity: 0.7;
    letter-spacing: 0.05em;
  }

  .cta {
    display: inline-block;
    padding: 0.8rem 2.5rem;
    border: 1px solid white;
    color: white;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.85rem;
    transition: all 0.3s ease;
  }

  .cta:hover {
    background: white;
    color: var(--color-text);
  }
</style>
