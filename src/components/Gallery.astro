---
import fs from 'node:fs';
import path from 'node:path';
import sizeOf from 'image-size';

interface Photo {
  src: string;
  landscape: boolean;
}

function listPhotos(dir: string): Photo[] {
  const fullPath = path.resolve('public/photos', dir);
  if (!fs.existsSync(fullPath)) return [];
  return fs.readdirSync(fullPath)
    .filter(f => /\.(jpe?g|png|webp)$/i.test(f))
    .sort()
    .map(f => {
      const filePath = path.join(fullPath, f);
      const buffer = fs.readFileSync(filePath);
      const dims = sizeOf(buffer);
      return {
        src: `/photos/${dir}/${f}`,
        landscape: (dims.width || 0) >= (dims.height || 0),
      };
    });
}

const exterieur = listPhotos('exterieur');
const piscine = listPhotos('piscine');
---

<section id="galerie" class="gallery">
  <h2>Le lieu</h2>

  {exterieur.length > 0 && (
    <div class="gallery-grid">
      {exterieur.map(({ src, landscape }) => (
        <div class:list={['photo', landscape ? 'wide' : 'tall']}>
          <img src={src} alt="Le Rambert — extérieur" loading="lazy" />
        </div>
      ))}
    </div>
  )}

  {piscine.length > 0 && (
    <>
      <h3>La piscine</h3>
      <div class="gallery-grid">
        {piscine.map(({ src, landscape }) => (
          <div class:list={['photo', landscape ? 'wide' : 'tall']}>
            <img src={src} alt="Le Rambert — piscine" loading="lazy" />
          </div>
        ))}
      </div>
    </>
  )}

  {exterieur.length === 0 && piscine.length === 0 && (
    <div class="placeholder">Photos à ajouter</div>
  )}
</section>

<style>
  .gallery {
    padding: 6rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  .gallery h2 {
    font-family: var(--font-heading);
    font-size: 2rem;
    margin-bottom: 3rem;
    font-weight: 400;
  }

  .gallery h3 {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 400;
    margin: 3rem 0 1.5rem;
    color: var(--color-accent);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 200px;
    grid-auto-flow: dense;
    gap: 0.5rem;
  }

  .photo.wide {
    grid-column: span 2;
    grid-row: span 1;
  }

  .photo.tall {
    grid-column: span 1;
    grid-row: span 2;
  }

  .photo {
    overflow: hidden;
    border-radius: 3px;
  }

  .photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .photo:hover img {
    transform: scale(1.03);
  }

  @media (max-width: 900px) {
    .gallery-grid {
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: 140px;
    }
  }

  @media (max-width: 600px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 120px;
    }
  }

  .placeholder {
    background: var(--color-light);
    padding: 4rem 2rem;
    color: var(--color-accent);
    font-style: italic;
  }
</style>
