---
import fs from 'node:fs';
import path from 'node:path';
import sizeOf from 'image-size';
import { t, type Lang } from '../i18n/utils';

interface Photo {
  src: string;
  landscape: boolean;
  colSpan: number;
}

function listPhotos(dir: string): Photo[] {
  const fullPath = path.resolve('public/photos', dir);
  if (!fs.existsSync(fullPath)) return [];
  return fs.readdirSync(fullPath)
    .filter(f => /\.(jpe?g|png|webp)$/i.test(f))
    .sort()
    .map(f => {
      const filePath = path.join(fullPath, f);
      const buffer = fs.readFileSync(filePath);
      const dims = sizeOf(buffer);
      const landscape = (dims.width || 0) >= (dims.height || 0);
      return { src: `/photos/${dir}/${f}`, landscape, colSpan: landscape ? 2 : 1 };
    });
}

// Calcule le nombre optimal de colonnes et promote des portraits
// en span 2 pour combler la dernière rangée
function optimizeGrid(photos: Photo[]): number {
  const totalSpan = photos.reduce((sum, p) => sum + p.colSpan, 0);
  if (totalSpan <= 4) return totalSpan;

  const portraitCount = photos.filter(p => p.colSpan === 1).length;

  let bestCols = 4;
  let bestExtra = Infinity;
  for (const cols of [4, 3, 2]) {
    const remainder = totalSpan % cols;
    const extra = remainder === 0 ? 0 : cols - remainder;
    if (extra <= portraitCount && (extra < bestExtra || (extra === bestExtra && cols > bestCols))) {
      bestExtra = extra;
      bestCols = cols;
    }
  }

  // Élargir les derniers portraits pour combler le trou
  let promoted = 0;
  for (let i = photos.length - 1; i >= 0 && promoted < bestExtra; i--) {
    if (photos[i].colSpan === 1) {
      photos[i].colSpan = 2;
      promoted++;
    }
  }

  return bestCols;
}

interface Props {
  lang?: Lang;
}
const { lang = 'fr' } = Astro.props;

const exterieur = listPhotos('exterieur');
const piscine = listPhotos('piscine');
const colsExterieur = optimizeGrid(exterieur);
const colsPiscine = optimizeGrid(piscine);
---

<section id="galerie" class="gallery">
  <p class="section-tag">{t(lang, 'gallery.tag')}</p>
  <h2 class="section-title" set:html={t(lang, 'gallery.title')} />
  <p class="section-lead">{t(lang, 'gallery.lead')}</p>

  {exterieur.length > 0 && (
    <div class="gallery-grid" style={`--cols: ${colsExterieur}`}>
      {exterieur.map(({ src, colSpan }) => (
        <div class:list={['photo', colSpan === 2 ? 'wide' : 'tall']}>
          <img src={src} alt={t(lang, 'gallery.alt.exterior')} loading="lazy" />
        </div>
      ))}
    </div>
  )}

  {piscine.length > 0 && (
    <>
      <h3>{t(lang, 'gallery.pool')}</h3>
      <div class="gallery-grid" style={`--cols: ${colsPiscine}`}>
        {piscine.map(({ src, colSpan }) => (
          <div class:list={['photo', colSpan === 2 ? 'wide' : 'tall']}>
            <img src={src} alt={t(lang, 'gallery.alt.pool')} loading="lazy" />
          </div>
        ))}
      </div>
    </>
  )}

  {exterieur.length === 0 && piscine.length === 0 && (
    <div class="placeholder">{t(lang, 'gallery.placeholder')}</div>
  )}
</section>

<style>
  .gallery {
    background: var(--color-deep);
    padding: 6rem 2rem;
  }

  .gallery :global(.section-tag) {
    text-align: center;
  }

  .gallery :global(.section-title) {
    color: var(--color-bg);
    text-align: center;
  }

  .gallery :global(.section-title em) {
    color: var(--color-light);
  }

  .gallery :global(.section-lead) {
    color: var(--color-light);
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }

  .gallery h3 {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 400;
    margin: 3rem 0 1.5rem;
    color: var(--color-bg);
    text-align: center;
  }

  .gallery-grid {
    max-width: 1200px;
    margin: 0 auto;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(var(--cols, 4), 1fr);
    grid-auto-rows: 200px;
    grid-auto-flow: dense;
    gap: 0.5rem;
  }

  .photo.wide {
    grid-column: span 2;
    grid-row: span 2;
  }

  .photo.tall {
    grid-column: span 1;
    grid-row: span 2;
  }

  .photo {
    overflow: hidden;
    border-radius: 3px;
  }

  .photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
    cursor: pointer;
  }

  .photo:hover img {
    transform: scale(1.03);
  }

  @media (max-width: 900px) {
    .gallery-grid {
      grid-template-columns: repeat(min(var(--cols, 4), 3), 1fr);
      grid-auto-rows: 140px;
    }
  }

  @media (max-width: 600px) {
    .gallery-grid {
      grid-template-columns: repeat(min(var(--cols, 4), 2), 1fr);
      grid-auto-rows: 120px;
    }
  }

  .placeholder {
    background: var(--color-light);
    padding: 4rem 2rem;
    color: var(--color-accent);
    font-style: italic;
  }
</style>
