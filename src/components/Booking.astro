---
// Section réservation : calendrier + formulaire de contact côte à côte
// Clic sur jours disponibles → pré-remplit les dates dans le message
---

<section id="disponibilites" class="booking" data-animate>
  <div class="booking-header">
    <p class="section-tag">Réservation</p>
    <h2 class="section-title">Disponibilités & <em>contact</em></h2>
    <p class="section-lead">Sélectionnez vos dates sur le calendrier, puis envoyez-nous un message</p>
  </div>

  <div class="booking-layout">
    <!-- Calendrier -->
    <div class="booking-calendar">
      <div class="calendar-container">
        <div class="calendar-nav">
          <button class="cal-prev" aria-label="Mois précédent">&#8249;</button>
          <span class="cal-nav-label"></span>
          <button class="cal-next" aria-label="Mois suivant">&#8250;</button>
        </div>
        <div class="cal-grid">
          <div class="cal-header">
            <span>Lun</span><span>Mar</span><span>Mer</span><span>Jeu</span><span>Ven</span><span>Sam</span><span>Dim</span>
          </div>
          <div class="cal-days"></div>
        </div>
        <div class="cal-legend">
          <span class="legend-item"><span class="dot available"></span> Disponible</span>
          <span class="legend-item"><span class="dot booked"></span> Réservé</span>
          <span class="legend-item"><span class="dot selected"></span> Sélection</span>
        </div>
        <p class="cal-hint">Cliquez sur un jour disponible pour choisir vos dates</p>
      </div>
      <div class="cal-loading">Chargement…</div>
      <div class="cal-error" hidden>Calendrier indisponible.</div>
    </div>

    <!-- Formulaire -->
    <div class="booking-form">
      <h3 class="form-title">Envoyez-nous un message</h3>
      <form class="contact-form" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field">
        <p class="hp" aria-hidden="true">
          <label>Ne pas remplir : <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
        </p>
        <input type="hidden" name="form-name" value="contact" />
        <input type="text" name="name" placeholder="Nom" required />
        <input type="email" name="email" placeholder="Email" required />
        <input type="tel" name="phone" placeholder="Téléphone (optionnel)" />
        <textarea name="message" rows="8" required></textarea>
        <button type="submit" disabled>Envoyer</button>
      </form>
    </div>
  </div>
</section>

<style>
  .booking {
    padding: 6rem 2rem;
    background: var(--color-warm-white);
  }

  .booking-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .booking-header :global(.section-lead) {
    margin: 0 auto 3rem;
  }

  .booking-layout {
    max-width: 1000px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* --- Calendrier --- */

  .booking-calendar {
    text-align: center;
  }

  .calendar-container {
    display: none;
  }

  .calendar-container.loaded {
    display: block;
  }

  .calendar-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .cal-nav-label {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 400;
    color: var(--color-text);
    min-width: 180px;
  }

  .cal-prev, .cal-next {
    background: none;
    border: 1px solid var(--color-light);
    width: 2.2rem;
    height: 2.2rem;
    font-size: 1.3rem;
    color: var(--color-accent);
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cal-prev:hover, .cal-next:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }

  .cal-header {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
    margin-bottom: 4px;
  }

  .cal-header span {
    font-size: 0.7rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-taupe);
    padding: 0.5rem 0;
  }

  .cal-days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
  }

  :global(.cal-day) {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 400;
    transition: all 0.2s;
  }

  :global(.cal-day.empty) {
    background: none;
  }

  :global(.cal-day.available) {
    background: rgba(184, 150, 90, 0.12);
    color: var(--color-text);
    font-weight: 400;
    cursor: pointer;
  }

  :global(.cal-day.available:hover) {
    background: rgba(184, 150, 90, 0.25);
  }

  :global(.cal-day.today) {
    border: 2px solid var(--color-gold);
    font-weight: 500;
  }

  :global(.cal-day.booked) {
    background: #D5CCC2;
    color: #A89B8C;
    text-decoration: line-through;
    text-decoration-color: #A89B8C;
  }

  :global(.cal-day.past) {
    color: #D4C5B2;
    background: none;
  }

  :global(.cal-day.selected) {
    background: var(--color-gold);
    color: white;
    font-weight: 500;
    text-decoration: none;
  }

  :global(.cal-day.in-range) {
    background: rgba(184, 150, 90, 0.3);
    color: var(--color-text);
    font-weight: 400;
  }

  .cal-legend {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    color: var(--color-taupe);
  }

  .dot {
    width: 10px;
    height: 10px;
    display: inline-block;
  }

  .dot.available {
    background: rgba(184, 150, 90, 0.15);
  }

  .dot.booked {
    background: #D5CCC2;
  }

  .dot.selected {
    background: var(--color-gold);
  }

  .cal-hint {
    font-size: 0.72rem;
    color: var(--color-taupe);
    margin-top: 0.8rem;
    font-style: italic;
  }

  .cal-loading {
    color: var(--color-taupe);
    font-style: italic;
    font-size: 0.85rem;
    text-align: center;
  }

  .cal-error {
    color: var(--color-accent);
    font-size: 0.85rem;
    padding: 1.5rem;
    background: var(--color-stone);
    text-align: center;
  }

  /* --- Formulaire --- */

  .booking-form {
    display: flex;
    flex-direction: column;
  }

  .form-title {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 400;
    color: var(--color-text);
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .hp {
    position: absolute;
    left: -9999px;
    height: 0;
    overflow: hidden;
  }

  .contact-form input,
  .contact-form textarea {
    font-family: var(--font-body);
    font-size: 0.88rem;
    font-weight: 300;
    padding: 0.9rem 1rem;
    border: 1px solid var(--color-stone);
    background: white;
    color: var(--color-text);
    outline: none;
    transition: border-color 0.3s;
  }

  .contact-form input:focus,
  .contact-form textarea:focus {
    border-color: var(--color-gold);
  }

  .contact-form textarea {
    resize: vertical;
    min-height: 160px;
  }

  .contact-form button {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 1rem 2.5rem;
    background: var(--color-text);
    color: var(--color-bg);
    border: none;
    cursor: pointer;
    transition: all 0.3s;
    align-self: center;
    margin-top: 0.5rem;
  }

  .contact-form button:hover:not(:disabled) {
    background: var(--color-gold);
    color: var(--color-deep);
  }

  .contact-form button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  :global(.form-success) {
    text-align: center;
    color: var(--color-accent);
    font-size: 1rem;
    padding: 2rem 0;
    font-weight: 400;
  }

  :global(.form-error) {
    text-align: center;
    color: #a04040;
    font-size: 0.82rem;
    margin-top: 0.5rem;
  }

  /* --- Mobile --- */

  @media (max-width: 768px) {
    .booking-layout {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    :global(.cal-day) {
      font-size: 0.75rem;
    }

    .cal-nav-label {
      font-size: 1.1rem;
      min-width: 140px;
    }
  }
</style>

<script>
  const MONTHS_FR = [
    'Janvier', 'Février', 'Mars', 'Avril', 'Mai', 'Juin',
    'Juillet', 'Août', 'Septembre', 'Octobre', 'Novembre', 'Décembre'
  ];

  interface BookedEvent {
    start: string;
    end: string;
  }

  let events: BookedEvent[] = [];
  let currentYear: number;
  let currentMonth: number;

  // Sélection de dates
  let selectedStart: string | null = null;
  let selectedEnd: string | null = null;

  const container = document.querySelector('.calendar-container') as HTMLElement;
  const loading = document.querySelector('.cal-loading') as HTMLElement;
  const errorEl = document.querySelector('.cal-error') as HTMLElement;
  const navLabel = document.querySelector('.cal-nav-label') as HTMLElement;
  const daysGrid = document.querySelector('.cal-days') as HTMLElement;
  const textarea = document.querySelector('.contact-form textarea') as HTMLTextAreaElement;
  const form = document.querySelector('.contact-form') as HTMLFormElement;
  const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;

  // Anti-bot : activer le bouton après 3 secondes
  setTimeout(() => { submitBtn.disabled = false; }, 3000);

  // Soumission via fetch (pour afficher une confirmation sans quitter la page)
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Envoi…';

    try {
      const res = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(new FormData(form) as any).toString(),
      });

      if (res.ok) {
        form.innerHTML = '<p class="form-success">Message envoyé ! Nous vous répondrons rapidement.</p>';
      } else {
        submitBtn.textContent = 'Envoyer';
        submitBtn.disabled = false;
        form.insertAdjacentHTML('beforeend', '<p class="form-error">Erreur lors de l\'envoi. Réessayez ou contactez-nous directement.</p>');
      }
    } catch {
      submitBtn.textContent = 'Envoyer';
      submitBtn.disabled = false;
      form.insertAdjacentHTML('beforeend', '<p class="form-error">Erreur de connexion. Réessayez.</p>');
    }
  });

  const now = new Date();
  currentYear = now.getFullYear();
  currentMonth = now.getMonth();

  // Message template
  function buildMessage(): string {
    const dateLine = selectedStart && selectedEnd
      ? `du ${formatDateFR(selectedStart)} au ${formatDateFR(selectedEnd)}`
      : 'du ........ au ........';

    return `Bonjour,\n\nNous souhaiterions réserver Le Rambert ${dateLine}.\nNous serons .... personnes (dont .... enfants).\n\nMerci !`;
  }

  function formatDateFR(dateStr: string): string {
    const [y, m, d] = dateStr.split('-').map(Number);
    const date = new Date(y, m - 1, d);
    return date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
  }

  // Init message template
  textarea.value = buildMessage();

  document.querySelector('.cal-prev')?.addEventListener('click', () => navigate(-1));
  document.querySelector('.cal-next')?.addEventListener('click', () => navigate(1));

  // Event delegation pour les clics sur les jours
  daysGrid.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!target.classList.contains('available') && !target.classList.contains('in-range') && !target.classList.contains('selected')) return;

    const dateStr = target.dataset.date;
    if (!dateStr) return;

    if (!selectedStart || (selectedStart && selectedEnd)) {
      // Premier clic ou reset
      selectedStart = dateStr;
      selectedEnd = null;
    } else {
      // Deuxième clic
      if (dateStr < selectedStart) {
        selectedEnd = selectedStart;
        selectedStart = dateStr;
      } else if (dateStr === selectedStart) {
        // Clic sur le même jour → reset
        selectedStart = null;
        selectedEnd = null;
      } else {
        selectedEnd = dateStr;
      }

      // Vérifier qu'il n'y a pas de jours réservés dans la plage
      if (selectedStart && selectedEnd && hasBookedInRange(selectedStart, selectedEnd)) {
        // Reset si la plage contient des jours réservés
        selectedStart = dateStr;
        selectedEnd = null;
      }
    }

    textarea.value = buildMessage();
    render();
  });

  function hasBookedInRange(start: string, end: string): boolean {
    const d = new Date(start);
    const endDate = new Date(end);
    while (d <= endDate) {
      const ds = toDateStr(d.getFullYear(), d.getMonth(), d.getDate());
      if (isBooked(ds)) return true;
      d.setDate(d.getDate() + 1);
    }
    return false;
  }

  function navigate(delta: number) {
    currentMonth += delta;
    if (currentMonth > 11) { currentMonth = 0; currentYear++; }
    if (currentMonth < 0) { currentMonth = 11; currentYear--; }
    render();
  }

  function isBooked(dateStr: string): boolean {
    return events.some(e => dateStr >= e.start && dateStr < e.end);
  }

  function isInRange(dateStr: string): boolean {
    if (!selectedStart || !selectedEnd) return false;
    return dateStr > selectedStart && dateStr < selectedEnd;
  }

  function isSelected(dateStr: string): boolean {
    return dateStr === selectedStart || dateStr === selectedEnd;
  }

  function toDateStr(y: number, m: number, d: number): string {
    return `${y}-${String(m + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
  }

  function render() {
    navLabel.textContent = `${MONTHS_FR[currentMonth]} ${currentYear}`;

    const firstDay = new Date(currentYear, currentMonth, 1);
    const totalDays = new Date(currentYear, currentMonth + 1, 0).getDate();

    let startDow = firstDay.getDay() - 1;
    if (startDow < 0) startDow = 6;

    const todayStr = toDateStr(now.getFullYear(), now.getMonth(), now.getDate());

    let html = '';
    for (let i = 0; i < startDow; i++) {
      html += '<div class="cal-day empty"></div>';
    }

    for (let d = 1; d <= totalDays; d++) {
      const dateStr = toDateStr(currentYear, currentMonth, d);
      const isPast = dateStr < todayStr;
      const isToday = dateStr === todayStr;
      const booked = isBooked(dateStr);

      let cls = 'cal-day';
      if (isPast) {
        cls += ' past';
      } else if (isSelected(dateStr)) {
        cls += ' selected';
      } else if (isInRange(dateStr)) {
        cls += ' in-range';
      } else if (booked) {
        cls += ' booked';
      } else {
        cls += ' available';
      }
      if (isToday) cls += ' today';

      html += `<div class="${cls}" data-date="${dateStr}">${d}</div>`;
    }

    daysGrid.innerHTML = html;
  }

  async function init() {
    try {
      const res = await fetch('/api/calendar');
      if (!res.ok) throw new Error(`${res.status}`);
      const data = await res.json();
      events = data.events || [];
      loading.hidden = true;
      container.classList.add('loaded');
      render();
    } catch {
      loading.hidden = true;
      errorEl.hidden = false;
    }
  }

  init();
</script>
