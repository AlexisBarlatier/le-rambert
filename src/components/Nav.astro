---
import { t, type Lang, getLocalizedPath, getAlternateLang } from '../i18n/utils';

interface Props {
  title: string;
  lang?: Lang;
}
const { title, lang = 'fr' } = Astro.props;
const [before, last] = [title.split(' ').slice(0, -1).join(' '), title.split(' ').pop()];
---

<nav id="nav">
  <div class="nav-brand">{before} <span>{last}</span></div>
  <ul class="nav-links">
    <li><a href="#espaces">{t(lang, 'nav.espaces')}</a></li>
    <li><a href="#galerie">{t(lang, 'nav.galerie')}</a></li>
    <li><a href="#commodites">{t(lang, 'nav.equipements')}</a></li>
    <li><a href="#perigord">{t(lang, 'nav.perigord')}</a></li>
    <li><a href="#tarifs">{t(lang, 'nav.tarifs')}</a></li>
    <li><a href="#disponibilites">{t(lang, 'nav.reservation')}</a></li>
  </ul>
  <button class="nav-cta" onclick="document.getElementById('disponibilites').scrollIntoView({behavior:'smooth'})">{t(lang, 'nav.cta')}</button>
  <div class="lang-switch">
    <a href="/" class:list={[{active: lang === 'fr'}]} onclick="document.cookie='rambert_lang=fr;path=/;max-age=31536000'">FR</a>
    <span>|</span>
    <a href="/en/" class:list={[{active: lang === 'en'}]} onclick="document.cookie='rambert_lang=en;path=/;max-age=31536000'">EN</a>
  </div>
</nav>

<style>
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 1.2rem 3rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(250, 246, 241, 0.85);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(212, 197, 178, 0.3);
    transition: all 0.4s;
  }

  nav.scrolled {
    padding: 0.8rem 3rem;
    box-shadow: 0 2px 30px rgba(30, 21, 16, 0.06);
  }

  .nav-brand {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 500;
    color: var(--color-text);
    letter-spacing: 0.02em;
  }

  .nav-brand span {
    color: var(--color-gold);
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
  }

  .nav-links a {
    text-decoration: none;
    color: var(--color-accent);
    font-size: 0.82rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    position: relative;
    transition: color 0.3s;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -4px; left: 0;
    width: 0;
    height: 1px;
    background: var(--color-gold);
    transition: width 0.3s ease;
  }

  .nav-links a:hover {
    color: var(--color-gold);
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  .nav-cta {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.65rem 1.8rem;
    background: var(--color-text);
    color: var(--color-bg);
    border: none;
    cursor: pointer;
    transition: all 0.3s;
  }

  .nav-cta:hover {
    background: var(--color-gold);
  }

  .lang-switch {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: 1rem;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
  }

  .lang-switch a {
    text-decoration: none;
    color: var(--color-taupe);
    transition: color 0.3s;
  }

  .lang-switch a.active {
    color: var(--color-gold);
    font-weight: 500;
  }

  .lang-switch a:hover {
    color: var(--color-gold);
  }

  .lang-switch span {
    color: var(--color-light);
  }

  @media (max-width: 768px) {
    nav { padding: 1rem 1.5rem; }
    .nav-links { display: none; }
  }
</style>

<script>
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 60);
  });
</script>
