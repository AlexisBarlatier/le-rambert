---
import fs from 'node:fs';
import path from 'node:path';
import matter from 'gray-matter';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Description from '../components/Description.astro';
import Gallery from '../components/Gallery.astro';
import Amenities from '../components/Amenities.astro';
import Activities from '../components/Activities.astro';
import Pricing from '../components/Pricing.astro';
import Contact from '../components/Contact.astro';

const siteFile = fs.readFileSync(path.resolve('src/content/site.md'), 'utf-8');
const { data: site } = matter(siteFile);
---

<Layout title={`${site.title} — Location de vacances en Dordogne`}>
  <Nav title={site.title} />
  <Hero title={site.title} subtitle={site.subtitle} location={site.location} />
  <Description intro={site.intro} espaces={site.espaces} chambres={site.chambres} salles_de_bain={site.salles_de_bain} />
  <Gallery />
  <Amenities commodites={site.commodites} />
  <Activities activites={site.activites} />
  <Pricing tarifs={site.tarifs} />
  <Contact />
</Layout>
