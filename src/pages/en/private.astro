---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import PrivateGallery from '../../components/PrivateGallery.astro';
import { t } from '../../i18n/utils';

const lang = 'en' as const;

const sessionCookie = Astro.cookies.get('rambert_session')?.value;
if (!sessionCookie) {
  return Astro.redirect('/en/#acces-prive');
}
---

<Layout title={t(lang, 'privatePage.title')} description="Private access — photos, address and practical guide" lang={lang}>
  <header class="private-header">
    <a href="/en/" class="back">{t(lang, 'privatePage.back')}</a>
    <h1>{t(lang, 'privatePage.title')}</h1>
    <p class="subtitle">{t(lang, 'privatePage.subtitle')}</p>
  </header>

  <PrivateGallery lang={lang} />
</Layout>

<style>
  .private-header {
    text-align: center;
    padding: 4rem 2rem 2rem;
  }

  .private-header h1 {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: var(--color-accent);
    font-style: italic;
  }

  .back {
    display: inline-block;
    margin-bottom: 2rem;
    text-decoration: none;
    font-size: 0.9rem;
  }
</style>
